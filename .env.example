# Datey - Important Date Reminder
#
# These values are read at startup. Every variable below (except DATA_DIR) can
# additionally be overridden by an administrator via Settings -> Configuration
# in the admin UI; the database value takes precedence over the env value.
# Fields marked (restart required) are persisted but only applied on next boot.
# DATA_DIR is env-only and shown read-only in the admin UI.

## Server
PORT=6270              # (restart required)
DATA_DIR=/db           # env-only, not DB-overridable
DEBUG=0

## Logging
LOG_LEVEL=warn
LOG_BUFFER_SIZE=10000  # (restart required)
OTEL_ENDPOINT=         # (restart required)

## Scheduler
SCHEDULER_HOUR=8       # (restart required)
REMINDER_DAYS=7

## Database Backup
BACKUP_DIR=/db/backups
BACKUP_RETENTION_DAYS=30

## Email (SMTP) Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-password
SMTP_TLS=true
SMTP_TIMEOUT=10
NOTIFICATION_EMAIL=your@email.com

## Gotify Notifications
GOTIFY_URL=https://gotify.example.com
GOTIFY_TOKEN=your-gotify-token

## Telegram Notifications
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

## Analytics (Umami)
UMAMI_URL=https://umami.example.com
UMAMI_WEBSITE_ID=your-website-uuid

## Appearance
EINK_MODE=false
